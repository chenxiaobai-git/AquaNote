{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:5173",
    "distDir": "../dist"
  },
  "package": {
    "productName": "AquaNote",
    "version": "2026.6.0"
  },
  "tauri": {
    "bundle": {
      "active": true,
      "identifier": "com.aquanote",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "windows": {
        "nsis": {
          "installMode": "both"
        }
      }
    },
    "windows": [
      {
        "title": "AquaNote",
        "width": 1366,
        "height": 768,
        "resizable": false,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
