{
  "name": "aquanote",
  "version": "2026.6.0",
  "description": "AquaNote - 水族养护科研级软件",
  "author": "ChenXiaobai",
  "license": "MIT",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:win": "electron-builder --win"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "lucide-react": "^0.436.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "vite": "^5.4.2",
    "electron": "^31.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.chenxiaobai.aquanote",
    "productName": "AquaNote",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "dist/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/images/logo/aquanote-logo.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
