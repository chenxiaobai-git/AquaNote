{
  "name": "aquanote",
  "version": "62.26.6.1",
  "description": "AquaNote - 水族养护科研级软件",
  "main": "main.js",
  "author": "ChenXiaobai",
  "license": "MIT",
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^25.1.8"
  },
  "scripts": {
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac"
  },
  "build": {
    "appId": "com.chenxiaobai.aquanote",
    "productName": "AquaNote",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "../dist/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "../public/images/logo/aquanote-logo.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "../public/images/logo/aquanote-logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
